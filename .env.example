# ════════════════════════════════════════════════════════════════════════
# Firebase configuration (optional).
#
# Copy this file to `.env` and fill in the values from your Firebase project:
#   Firebase console → Project settings → Your apps → Web app → SDK config.
#
# These VITE_* values are read at BUILD time. The Firebase web config is NOT a
# secret — it ships to the browser by design; security is enforced by Firebase
# Auth + the rules in firestore.rules.
#
# If these are left blank, the app runs in localStorage-only mode (no cloud
# sync, convenience-gate password instead of real auth).
#
# For the GitHub Pages deploy, set these same names as repository
# Settings → Secrets and variables → Actions → "New repository secret".
# ════════════════════════════════════════════════════════════════════════

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Comma-separated allow-list of approved trainer emails (client-side UX gate;
# the authoritative check is in firestore.rules). Example:
# VITE_ADMIN_EMAILS=trainer@gym.com,manager@gym.com
VITE_ADMIN_EMAILS=
