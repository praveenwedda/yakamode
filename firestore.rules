rules_version = '2';

// ════════════════════════════════════════════════════════════════════════
// Firestore security rules for Anytime Fitness – Canberra City.
//
// Data model: ONE shared gym dataset at  /app/shared  (decision: shared data).
// Access:     only the approved trainer emails listed below.
//
// ▶ EDIT the `approvedEmails()` list to your trainers' emails, then deploy:
//     firebase deploy --only firestore:rules
//   (or paste these rules into Firebase console → Firestore → Rules → Publish)
//
// These rules are the REAL access gate. The app's client-side allow-list
// (VITE_ADMIN_EMAILS) is only for a friendly "not authorised" message.
// ════════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    function approvedEmails() {
      return [
        'trainer@example.com'
        // , 'second-trainer@example.com'
      ];
    }

    function isApprovedTrainer() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email.lower() in approvedEmails();
    }

    // The single shared application document (and any future app-scoped docs).
    match /app/{docId} {
      allow read, write: if isApprovedTrainer();
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
